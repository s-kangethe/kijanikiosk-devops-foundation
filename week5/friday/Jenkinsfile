def VERSION = "NOT_SET"

pipeline {
    agent {
        docker {
            image 'myregistry/jenkins-node:18-git'
            args '-u root:root'
        }
    }

    options {
        timestamps()
    }

    environment {
        NEXUS_URL = 'http://192.168.100.129:8081'
        NEXUS_REPO = 'npm-hosted'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm

                script {
                    env.PIPELINE_START = sh(
                        script: 'date +%s',
                        returnStdout: true
                    ).trim()
                }
            }
        }

        stage('Lint (Simulated)') {
            steps {
                sh '''
                    echo "Lint stage running..."
                    echo "No Node app present - simulating lint checks"
                '''
            }
        }

        stage('Build (Simulated Artifact Creation)') {
            steps {
                sh '''
                    echo "Creating build artifact..."

                    mkdir -p dist

                    echo "KijaniKiosk build output" > dist/build.txt
                    echo "Build timestamp: $(date)" >> dist/build.txt
                '''
            }
        }

        stage('Verify') {
            parallel {

                stage('Test (Simulated)') {
                    steps {
                        sh '''
                            echo "Simulated test execution..."
                            echo "All checks passed"
                        '''
                    }
                }

                stage('Security Audit (Simulated)') {
                    steps {
                        sh '''
                            echo "Simulated security scan..."
                            echo "No vulnerabilities found"
                        '''
                    }
                }
            }
        }

        stage('Archive') {
            steps {
                sh '''
                    mkdir -p artifact

                    tar -czf artifact/kijanikiosk-payments.tar.gz dist
                '''

                archiveArtifacts artifacts: 'artifact/*.tar.gz', fingerprint: true
            }
        }

        stage('Versioning') {
            steps {
                script {

                    def gitSha = env.GIT_COMMIT ?
                        env.GIT_COMMIT.take(7) :
                        "nogit"

                    def buildNum = env.BUILD_NUMBER ?: "0"

                    VERSION = "1.0.0-${buildNum}-${gitSha}"
                    env.VERSION = VERSION

                    echo "Version generated: ${VERSION}"
                }
            }
        }

        stage('Publish to Nexus') {
            steps {

                withCredentials([
                    usernamePassword(
                        credentialsId: 'nexus-ci-token',
                        usernameVariable: 'NEXUS_USER',
                        passwordVariable: 'NEXUS_PASS'
                    )
                ]) {

                    script {

                        def artifactName =
                            "kijanikiosk-payments-${env.VERSION}.tar.gz"

                        def artifactUrl =
                            "${env.NEXUS_URL}/repository/${env.NEXUS_REPO}/${artifactName}"

                        echo "Docker Image: myregistry/jenkins-node:18-git"
                        echo "Artifact Name: ${artifactName}"
                        echo "Artifact URL: ${artifactUrl}"

                        sh '''
                            echo "Preparing upload..."
                            ls -lah artifact/
                        '''

                        sh """
                            curl -u \$NEXUS_USER:\$NEXUS_PASS \
                            --upload-file artifact/kijanikiosk-payments.tar.gz \
                            ${artifactUrl}
                        """

                        echo "Artifact successfully uploaded to Nexus"
                    }
                }
            }
        }
    }

    post {

        always {
            script {

                def pipelineEnd = sh(
                    script: 'date +%s',
                    returnStdout: true
                ).trim()

                def runtime =
                    pipelineEnd.toInteger() -
                    env.PIPELINE_START.toInteger()

                echo "=============================="
                echo "PIPELINE SUMMARY"
                echo "=============================="

                echo "Docker Image: myregistry/jenkins-node:18-git"

                echo "Version: ${env.VERSION}"

                echo "Parallel Stages Executed:"
                echo "- Test (Simulated)"
                echo "- Security Audit (Simulated)"

                echo "Masked Credentials: ENABLED"

                echo "Artifact URL:"
                echo "${env.NEXUS_URL}/repository/${env.NEXUS_REPO}/kijanikiosk-payments-${env.VERSION}.tar.gz"

                echo "Pipeline Runtime: ${runtime} seconds"

                if (runtime < 600) {
                    echo "Runtime Requirement: PASSED (<10 minutes)"
                } else {
                    echo "Runtime Requirement: FAILED"
                }

                echo "=============================="
            }
        }

        success {
            echo "PIPELINE STATUS: SUCCESS"
        }

        failure {
            echo "PIPELINE STATUS: FAILURE"
        }

        cleanup {
            cleanWs()
        }
    }
}
