pipeline {
  agent { docker { image 'node:18.17.1-alpine' } }

  options {
    timeout(time: 10, unit: 'MINUTES')
    buildDiscarder(logRotator(numToKeepStr: '20'))
    ansiColor('xterm')
  }

  environment {
    // Explicit environment variables
    NEXUS_URL     = 'http://172.17.0.1:8081'
    NEXUS_REPO    = 'npm-hosted'
    NEXUS_CRED_ID = 'nexus-ci-token'
    SEMVER_BASE   = '1.0.0'
    NODE_ENV      = 'production'
    TMPDIR        = "${WORKSPACE}/tmp"
  }

  stages {
    stage('Prepare') {
      steps {
        sh '''
          set -euo pipefail
          mkdir -p "${TMPDIR}"
          echo "Workspace: ${WORKSPACE}"
          node --version || true
          npm --version || true
        '''
      }
    }

    stage('Lint') {
      steps {
        sh '''
          set -euo pipefail
          npm ci
          npm run lint
        '''
      }
    }

    stage('Build') {
      steps {
        sh '''
          set -euo pipefail
          npm run build
        '''
      }
    }

    stage('Set Nexus Host') {
      steps {
        script {
          // Use Java URI parsing to avoid Groovy string escaping issues
          def uri = new URI(env.NEXUS_URL)
          def nexusHost = uri.getHost()
          def nexusPort = uri.getPort()
          def nexusHostPort = nexusPort > 0 ? "${nexusHost}:${nexusPort}" : nexusHost
          env.NEXUS_HOST = nexusHost
          env.NEXUS_HOST_PORT = nexusHostPort
          echo "NEXUS_URL: ${env.NEXUS_URL}"
          echo "NEXUS_HOST: ${env.NEXUS_HOST}"
          echo "NEXUS_HOST_PORT: ${env.NEXUS_HOST_PORT}"
        }
      }
    }

    stage('Version and Pack') {
      steps {
        sh '''
          set -euo pipefail
          GIT_SHA=$(git rev-parse --short HEAD)
          NEW_VER="${SEMVER_BASE}-${GIT_SHA}"
          npm version --no-git-tag-version "${NEW_VER}"
          echo "Version set to ${NEW_VER}"
          npm pack
          ls -la *.tgz
        '''
      }
    }

    stage('Verify (parallel)') {
      parallel {
        stage('Test') {
          steps {
            sh '''
              set -euo pipefail
              mkdir -p test-results
              npm test || true
            '''
          }
        }
        stage('Smoke') {
          steps {
            sh '''
              set -euo pipefail
              echo "Running smoke checks"
              # add smoke commands here
            '''
          }
        }
      }
    }

    stage('Publish') {
      steps {
        withCredentials([string(credentialsId: "${NEXUS_CRED_ID}", variable: 'NEXUS_TOKEN')]) {
          sh '''
            set -euo pipefail
            # find the package file
            PKG=$(ls -1 *.tgz | head -n1)
            if [ -z "${PKG}" ]; then
              echo "No package found to publish"
              exit 1
            fi

            # Example npm publish to Nexus (adjust registry URL and auth as needed)
            echo "Publishing ${PKG} to Nexus repository ${NEXUS_REPO} at ${NEXUS_HOST_PORT}"
            npm config set //${NEXUS_HOST_PORT}/repository/${NEXUS_REPO}/:_authToken "${NEXUS_TOKEN}"
            npm publish "${PKG}" --registry "http://${NEXUS_HOST_PORT}/repository/${NEXUS_REPO}/"
          '''
        }
      }
    }
  }

  post {
    success {
      echo 'Pipeline completed successfully'
    }
    failure {
      echo 'Pipeline failed — check console output'
    }
    always {
      sh 'du -sh "${TMPDIR}" || true'
    }
  }
}
