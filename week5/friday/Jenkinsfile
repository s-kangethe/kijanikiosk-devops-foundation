pipeline {

    agent {
        docker {
            image 'node:18.20.4-alpine'
            args '-u root:root'
        }
    }

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    environment {

        APP_NAME = 'kijanikiosk-payments'

        // Confirmed working Nexus host
        NEXUS_URL = 'http://192.168.100.129:8081'

        NEXUS_REPO = 'npm-hosted'

        VERSION = ''
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Lint (Simulated)') {
            steps {
                sh '''
                echo "Lint stage running..."
                echo "No Node app present - simulating lint checks"
                '''
            }
        }

        stage('Build (Simulated Artifact Creation)') {
            steps {
                sh '''
                echo "Creating build artifact..."

                mkdir -p dist

                echo "KijaniKiosk build output" > dist/app.txt
                echo "Build timestamp: $(date)" >> dist/app.txt
                '''
            }
        }

        stage('Verify') {

            parallel {

                stage('Test (Simulated)') {
                    steps {
                        sh '''
                        echo "Simulated test execution..."
                        echo "All checks passed"
                        '''
                    }
                }

                stage('Security Audit (Simulated)') {
                    steps {
                        sh '''
                        echo "Simulated security scan..."
                        echo "No vulnerabilities found"
                        '''
                    }
                }
            }
        }

        stage('Archive') {
            steps {
                sh '''
                mkdir -p artifact
                tar -czf artifact/${APP_NAME}.tar.gz dist
                '''

                archiveArtifacts artifacts: 'artifact/*.tar.gz', fingerprint: true
            }
        }

        stage('Versioning') {
            steps {
                script {
                    env.VERSION = "1.0.0-${env.GIT_COMMIT.take(7)}"
                    echo "Version generated: ${env.VERSION}"
                }
            }
        }

        stage('Setup Tools') {
            steps {
                sh '''
                apk add --no-cache curl
                '''
            }
        }

        stage('Publish to Nexus') {

            steps {

                withCredentials([usernamePassword(
                    credentialsId: 'nexus-ci-token',
                    usernameVariable: 'NEXUS_USER',
                    passwordVariable: 'NEXUS_PASS'
                )]) {

                    sh '''
                    set -e

                    echo "Preparing authentication..."

                    AUTH=$(echo -n "$NEXUS_USER:$NEXUS_PASS" | base64)

                    cat > .npmrc <<EOF
registry=${NEXUS_URL}/repository/${NEXUS_REPO}/
always-auth=true
//192.168.100.129:8081/repository/${NEXUS_REPO}/:_auth=${AUTH}
email=ci@kijanikiosk.com
EOF

                    echo "Uploading artifact to Nexus..."

                    curl -u $NEXUS_USER:$NEXUS_PASS \
                         --upload-file artifact/${APP_NAME}.tar.gz \
                         ${NEXUS_URL}/repository/${NEXUS_REPO}/${APP_NAME}-${VERSION}.tar.gz

                    rm -f .npmrc
                    '''
                }
            }
        }
    }

    post {

        always {
            cleanWs()
        }

        success {
            echo "SUCCESS: ${VERSION}"
            echo "Artifact published to Nexus"
        }

        failure {
            echo "PIPELINE FAILED"
        }

        changed {
            echo "PIPELINE STATE CHANGED"
        }
    }
}
